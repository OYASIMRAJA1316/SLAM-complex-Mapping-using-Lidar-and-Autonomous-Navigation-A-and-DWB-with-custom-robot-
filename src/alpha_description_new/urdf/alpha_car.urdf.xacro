<?xml version="1.0" encoding="utf-8"?>
<robot name="alpha" xmlns:xacro="http://ros.org/wiki/xacro" >
  <xacro:property name="M_PI"               value="3.1415926535897931"/>
  <xacro:property name="base_link_mass"     value="8.90"/>
  <xacro:property name="base_link_w"        value="0.750"/>  <!-- body length X -->
  <xacro:property name="base_link_h"        value="0.491"/>  <!-- body width  Y -->
  <xacro:property name="base_link_d"        value="0.620"/>  <!-- body height Z -->

  <xacro:property name="wheel_link_mass"    value="0.158" />
  <xacro:property name="wheel_link_radius"  value="0.1015"/> <!-- wheel radius 203mm dia / 2 -->
  <xacro:property name="wheel_link_length"  value="0.085"/>  <!-- wheel width -->

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.1265" rpy="0 0 0"/>  <!-- ground clearance: wheel_r(0.1015) + axle_below(0.025) -->
  </joint>

  <link
    name="base_link">
    <xacro:box_inertial m="${base_link_mass}" w="${base_link_w}" h="${base_link_h}" d="${base_link_d}"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://alpha_description_new/meshes/base_link.stl" />
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
    
   <collision>
  	<origin xyz="0 0 ${base_link_d/2}" rpy="0 0 0"/>
  	<geometry>
    	<box size="${base_link_w} ${base_link_h} ${base_link_d}" />
  	</geometry>
   </collision>
   
   
  </link>

  <link
    name="wheel_right_front_link">
    <xacro:cylinder_inertial m="${wheel_link_mass}" r="${wheel_link_radius}" h="${wheel_link_length}" />
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://alpha_description_new/meshes/wheel_right_front_link.stl" />
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin
        xyz="0 0 ${wheel_link_length/2.0}"
        rpy="0 0 0" />
      <geometry>
        <cylinder length="${wheel_link_length}" radius="${wheel_link_radius}"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>
  <joint
    name="wheel_right_front_joint"
    type="continuous">
    <origin xyz="0.210 -0.2685 -0.025"
        rpy="1.5708 1.5708 0"/>
    <parent
      link="base_link" />
    <child
      link="wheel_right_front_link" />
    <axis xyz="0 0 -1" />
  </joint>
  <link
    name="wheel_left_front_link">
    <xacro:cylinder_inertial m="${wheel_link_mass}" r="${wheel_link_radius}" h="${wheel_link_length}" />
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://alpha_description_new/meshes/wheel_left_front_link.stl" />
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin
        xyz="0 0 -${wheel_link_length/2.0}"
        rpy="0 0 0" />
      <geometry>
        <cylinder length="${wheel_link_length}" radius="${wheel_link_radius}"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>
  <joint
    name="wheel_left_front_joint"
    type="continuous">
    
    <origin xyz="0.210 0.2685 -0.025"
        rpy="1.5708 1.5708 0"/>
    <parent
      link="base_link" />
    <child
      link="wheel_left_front_link" />
    <axis xyz="0 0 -1" />
  </joint>
  <link
    name="wheel_right_back_link">
    <xacro:cylinder_inertial m="${wheel_link_mass}" r="${wheel_link_radius}" h="${wheel_link_length}" />
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://alpha_description_new/meshes/wheel_right_back_link.stl" />
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin
        xyz="0 0 ${wheel_link_length/2.0}"
        rpy="0 0 0" />
      <geometry>
        <cylinder length="${wheel_link_length}" radius="${wheel_link_radius}"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>
  <joint
    name="wheel_right_back_joint"
    type="continuous">
    <origin xyz="-0.210 -0.2685 -0.025"
        rpy="1.5708 1.5708 0"/>
    <parent
      link="base_link" />
    <child
      link="wheel_right_back_link" />
    <axis xyz="0 0 -1" />
  </joint>
  <link
    name="wheel_left_back_link">
    <xacro:cylinder_inertial m="${wheel_link_mass}" r="${wheel_link_radius}" h="${wheel_link_length}" />
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://alpha_description_new/meshes/wheel_left_back_link.stl" />
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin
        xyz="0 0 -${wheel_link_length/2.0}"
        rpy="0 0 0" />
      <geometry>
        <cylinder length="${wheel_link_length}" radius="${wheel_link_radius}"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>0.0</mu2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </link>
  <joint
    name="wheel_left_back_joint"
    type="continuous">
    <origin xyz="-0.210 0.2685 -0.025"
        rpy="1.5708 1.5708 0"/>
    <parent
      link="base_link" />
    <child
      link="wheel_left_back_link" />
    <axis xyz="0 0 -1" />
  </joint>



  <!-- Bumpers -->
  <link name="front_bumper_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://alpha_description_new/meshes/front_bumper.stl" />
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="front_bumper_joint" type="fixed">
    <origin xyz="0.010 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="front_bumper_link" />
  </joint>

  <link name="back_bumper_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://alpha_description_new/meshes/front_bumper.stl" />
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="back_bumper_joint" type="fixed">
    <origin xyz="-0.010 0 0" rpy="0 0 3.14159265" />
    <parent link="base_link" />
    <child link="back_bumper_link" />
  </joint>

  <gazebo reference="front_bumper_link">
    <material>
      <ambient>0.1 0.1 0.1 1.0</ambient>
      <diffuse>0.1 0.1 0.1 1.0</diffuse>
      <specular>0.05 0.05 0.05 1.0</specular>
    </material>
  </gazebo>
  
  <gazebo reference="back_bumper_link">
    <material>
      <ambient>0.1 0.1 0.1 1.0</ambient>
      <diffuse>0.1 0.1 0.1 1.0</diffuse>
      <specular>0.05 0.05 0.05 1.0</specular>
    </material>
  </gazebo>

  <!-- Transmission macro -->
  <xacro:macro name="SimpleTransmissionPosition" params="joint">
      <transmission name="tran_${joint}">
          <type>transmission_interface/SimpleTransmission</type>
          <joint name="${joint}">
              <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
          </joint>
          <actuator name="${joint}_motor">
              <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
              <mechanicalReduction>1</mechanicalReduction>
          </actuator>
      </transmission>
  </xacro:macro>
  <xacro:SimpleTransmissionPosition joint="joint1" />

  <gazebo>
    <plugin filename="gz-sim-mecanum-drive-system" name="gz::sim::systems::MecanumDrive">
      <front_left_joint>wheel_left_front_joint</front_left_joint>
      <back_left_joint>wheel_left_back_joint</back_left_joint>
      <front_right_joint>wheel_right_front_joint</front_right_joint>
      <back_right_joint>wheel_right_back_joint</back_right_joint>
      <wheel_separation>0.537</wheel_separation>
      <wheelbase>0.420</wheelbase>
      <wheel_radius>0.1015</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <odom_publish_frequency>50</odom_publish_frequency>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <material>
      <ambient>0.75 0.75 0.75 1.0</ambient>
      <diffuse>0.75 0.75 0.75 1.0</diffuse>
      <specular>0.5 0.5 0.5 1.0</specular>
    </material>
  </gazebo>
</robot>
